{
  "endpoint": "PUT /api/v1/subseries/{id}",
  "description": "Actualiza una subserie documental existente",
  "method": "PUT",
  "url": "http://localhost:8080/api/v1/subseries/5",
  "headers": {
    "Content-Type": "application/json",
    "Accept": "application/json"
  },
  "pathParameters": {
    "id": 5
  },
  "body": {
    "nombreSubserie": "PRUEBA - Subserie Trámites Iniciales Vejez (Actualizada)",
    "descripcion": "Subserie documental actualizada para trámites iniciales de pensiones de vejez con nueva información",
    "formatoDoc": "MIXTO",
    "seguridad": "RESERVADA",
    "normativa": "Ley de Seguridad Social - Artículo 123 (Actualizado)",
    "responsable": "0987654321",
    "estado": "Actualizado",
    "justificacion": "Actualización de la subserie para reflejar cambios en la normativa"
  },
  "note": "En PUT, solo envía los campos que quieres actualizar. Los campos no enviados se mantienen igual.",
  "examples": [
    {
      "description": "Actualizar solo nombre y descripción",
      "id": 5,
      "body": {
        "nombreSubserie": "PRUEBA - Subserie Trámites Iniciales Vejez (Actualizada)",
        "descripcion": "Descripción actualizada de la subserie"
      }
    },
    {
      "description": "Actualizar formato y seguridad",
      "id": 5,
      "body": {
        "formatoDoc": "DIGITAL",
        "seguridad": "PUBLICA"
      }
    },
    {
      "description": "Actualización completa",
      "id": 5,
      "body": {
        "nombreSubserie": "PRUEBA - Subserie Trámites Iniciales Vejez (Actualizada)",
        "descripcion": "Subserie documental actualizada",
        "formatoDoc": "MIXTO",
        "seguridad": "RESERVADA",
        "normativa": "Nueva normativa",
        "responsable": "0987654321",
        "justificacion": "Actualización completa de la subserie"
      }
    }
  ],
  "expectedResponse": {
    "statusCode": 200,
    "body": {
      "data": {
        "id": 5,
        "idSerie": 7,
        "nombreSubserie": "PRUEBA - Subserie Trámites Iniciales Vejez (Actualizada)",
        "descripcion": "Subserie documental actualizada para trámites iniciales",
        "formatoDoc": "MIXTO",
        "seguridad": "RESERVADA",
        "normativa": "Ley de Seguridad Social - Artículo 123 (Actualizado)",
        "responsable": "0987654321",
        "estado": "Actualizado",
        "justificacion": "Actualización de la subserie para reflejar cambios en la normativa",
        "usuCreacion": "1234567890",
        "fecCreacion": "2026-01-07T..."
      },
      "meta": {
        "timestamp": "2026-01-07T..."
      },
      "error": null
    }
  },
  "errorResponse": {
    "statusCode": 404,
    "body": {
      "data": null,
      "meta": null,
      "error": {
        "message": "Subserie no encontrada con ID: 999",
        "code": "SUBSERIE_NOT_FOUND",
        "details": null
      }
    }
  },
  "curlExample": "curl -X PUT 'http://localhost:8080/api/v1/subseries/5' -H 'Content-Type: application/json' -H 'Accept: application/json' -d '{\"nombreSubserie\":\"PRUEBA - Subserie Actualizada\",\"descripcion\":\"Descripción actualizada\"}'",
  "notes": [
    "Solo envía los campos que quieres actualizar; el resto se mantiene.",
    "El {id} en la URL es el de la subserie (campo data.id devuelto por POST crear o por GET /api/v1/subseries/{id}).",
    "Sustituir en url el número: http://localhost:8080/api/v1/subseries/<TU_ID>",
    "Si el id no existe, respuesta 404 con code SUBSERIE_NOT_FOUND"
  ]
}
